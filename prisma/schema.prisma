// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model GoldSettings {
  id                  String   @id @default(uuid())
  shop                String   @unique
  apiKey              String
  apiProvider         String   @default("goldapi")
  makingChargeType    String   @default("percentage")
  makingChargeValue   Float    @default(0.0)
  profitMarginType    String   @default("percentage")
  profitMarginValue   Float    @default(0.0)
  minRate24K          Float    @default(0.0)
  minRate22K          Float    @default(0.0)
  minRate18K          Float    @default(0.0)
  blockPriceDecreases Boolean  @default(false)
  autoPushOnIncrease  Boolean  @default(true)
  updateFrequency     String   @default( "daily")
  syncShopifyDomain   String   @default("")
  syncAccessToken     String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GoldRateCache {
  id        String   @id @default(uuid())
  shop      String   @unique
  rate24K   Float
  rate22K   Float
  rate18K   Float
  updatedAt DateTime @updatedAt
}

model GoldActivityLog {
  id                   String   @id @default(uuid())
  shop                 String
  timestamp            DateTime @default(now())
  status               String
  rate24K              Float
  rate22K              Float
  rate18K              Float
  productsUpdatedCount Int      @default(0)
  errorMessage         String?  @db.Text
}
